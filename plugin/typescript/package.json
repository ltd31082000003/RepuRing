{
    "name":  "canopy-plugin-typescript",
    "version":  "1.0.0",
    "description":  "TypeScript implementation of the Canopy blockchain plugin",
    "type":  "module",
    "main":  "dist/main.js",
    "types":  "dist/main.d.ts",
    "scripts":  {
                    "build":  "tsc -p tsconfig.json \u0026\u0026 npm run copy:proto",
                    "copy:proto":  "node -e \"const fs=require(\u0027fs\u0027);fs.mkdirSync(\u0027dist/proto\u0027,{recursive:true});for(const f of [\u0027index.js\u0027,\u0027index.cjs\u0027,\u0027index.d.ts\u0027])fs.copyFileSync(\u0027src/proto/\u0027+f,\u0027dist/proto/\u0027+f)\"",
                    "start":  "node dist/main.js",
                    "dev":  "nodemon --exec \u0027node --loader ts-node/esm src/main.ts\u0027",
                    "build:proto":  "node scripts/build-proto.cjs",
                    "build:descriptors":  "node scripts/generate-descriptors.cjs",
                    "build:all":  "npm run build:proto \u0026\u0026 npm run build:descriptors \u0026\u0026 npm run build",
                    "test":  "node scripts/test-repuring.cjs"
                },
    "dependencies":  {
                         "long":  "^5.2.3",
                         "protobufjs":  "^7.5.4"
                     },
    "devDependencies":  {
                            "@types/node":  "^20.19.11",
                            "nodemon":  "^3.0.2",
                            "protobufjs-cli":  "^1.1.1",
                            "ts-node":  "^10.9.1",
                            "typescript":  "^5.3.2"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                }
}
